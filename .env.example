# --- GoWA (go-whatsapp-web-multidevice) ---
GOWA_BASE_URL=https://gowa.example.com
GOWA_BASIC_AUTH=user:pass

# --- Gemini ---
GEMINI_API_KEY_FREE=
GEMINI_API_KEY_PAID=
# Retry order per conversation: free[primary, fallback] x3, then paid[primary, fallback] x3.
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# --- Schedule / scope ---
TIMEZONE=Asia/Dhaka
SCAN_HOUR=22
MAX_CHAT_ATTEMPTS=5
MAX_VIDEO_MB=10
MAX_MEDIA_ITEMS=30
MAX_TOTAL_MEDIA_MB=40
MAX_EMAIL_ATTACH_MB=18
MAX_EMAIL_CHUNKS=5

# --- Email: Resend OR SMTP ---
RESEND_API_KEY=
MAIL_FROM=bot@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true

# --- Telegram error alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Misc ---
LOG_LEVEL=INFO
# DB_PATH / USERS_FILE default to repo-local ./data and ./config for bare
# local runs. The Docker image sets them to /data and /config (volumes);
# only set them here if you want to override those defaults.
# DB_PATH=/data/summarizer.db
# USERS_FILE=/config/users.yaml
